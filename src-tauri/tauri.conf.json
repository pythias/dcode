{
  "$schema": "https://raw.githubusercontent.com/nicedoc/format-conf/main/schemas/tauri.json",
  "productName": "DCode",
  "version": "0.2.5",
  "identifier": "dev.dcode.ide",
  "build": {
    "frontendDist": "../ui/dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "cd ../ui && pnpm dev",
    "beforeBuildCommand": "cd ../ui && pnpm build"
  },
  "app": {
    "windows": [
      {
        "title": "DCode",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "decorations": true
      }
    ],
    "macOSPrivateApi": true,
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' asset: https://asset.localhost; font-src 'self'; connect-src ipc: http://ipc.localhost; worker-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "nsis", "deb", "appimage"],
    "icon": [
      "icons/icon.png",
      "icons/icon.ico",
      "icons/icon.icns"
    ]
  }
}
